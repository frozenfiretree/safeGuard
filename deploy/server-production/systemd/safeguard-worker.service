[Unit]
Description=SafeGuard Celery Worker
After=network.target redis.service

[Service]
Type=simple
WorkingDirectory=/opt/safeguard/server
EnvironmentFile=/etc/safeguard/server.env
ExecStart=/opt/conda/envs/scanocr/bin/celery -A tasks.celery_app worker --loglevel=INFO --concurrency=4
Restart=always
RestartSec=5
User=safeguard
Group=safeguard

[Install]
WantedBy=multi-user.target
