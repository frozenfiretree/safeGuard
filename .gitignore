# ---------------------------------------------------------------------------
# SafeGuard repository ignore rules
#
# Keep source code, deployment scripts, configuration examples, protobuf files,
# tests, and Markdown documentation in Git. Keep runtime data, local secrets,
# build outputs, binaries, OCR/AI models, caches, and generated user documents
# out of Git.
# ---------------------------------------------------------------------------

# Python caches and test caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Python virtual environments and local package metadata
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
*.egg-info/

# Node dependencies, package manager caches, and frontend build output
node_modules/
frontend/node_modules/
.npm/
.pnpm-store/
.yarn/
frontend/.vite/
frontend/.turbo/
frontend/dist/
frontend/build/
dist/

# IDE, editor, OS, and local assistant state
.idea/
.vscode/
.vs/
.claude/
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# Local environment files and secrets
.env
.env.*
!.env.example
deploy/server-production/.env
*.pem
*.key
*.crt
*.p12
*.pfx
*.token
secrets.*

# Local test/work directories
.codex_tmp_test/
.agent_local_dryrun/
.agent_local_fulltest/
tmp/
temp/
.tmp/
agent_work/
work_dir/
scan_root/
downloads/
mock_http/

# Runtime state generated by server and agent
server/data/
server/logs/
server/data/object_store/
server/data/tmp_uploads_v1/
server/data/guard_state/
server/data/assets/
agent_core/data/
agent_core/logs/

# Databases, queues, and logs
*.db
*.db-*
*.sqlite
*.sqlite3
*.sqlite3-*
*.log
*.log.*
*.pid

# Uploaded files, scan outputs, highlighted copies, and generated reports
uploads/
object_store/
guard_state/
reports/
exports/
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.csv
*.tsv
*.png
*.jpg
*.jpeg
*.bmp
*.gif
*.webp
*.tif
*.tiff

# Allow project documentation in Markdown
!*.md

# OCR, Paddle, LLM, and other AI model artifacts
server/artifacts/models/
server/artifacts/models.zip
deploy/**/models.zip
deploy/**/paddlex_models/
**/paddlex_models/
models/
model/
checkpoints/
weights/
*.pdmodel
*.pdiparams
*.pdiparams.info
*.pdparams
*.pdopt
*.pdstates
*.onnx
*.engine
*.trt
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.gguf
*.ggml
*.h5
*.keras
*.pb
*.tflite
*.npy
*.npz
*.pkl
*.pickle

# Keep source helpers in server/artifacts
!server/artifacts/
!server/artifacts/*.py

# Build outputs, packaged applications, and native binaries
build/
release/
out/
*.spec.bak
*.exe
*.dll
*.so
*.dylib
*.msi
*.app
*.dmg
*.pkg

# Archives and compressed generated bundles
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.gz

# Preserve intentionally committed examples even if archive rules are broad
!.env.example

# Commit the built-in web UI served by the backend.
!server/webui/
!server/webui/**
