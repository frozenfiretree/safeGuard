# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Node / frontend dependencies and build output
node_modules/
frontend/node_modules/
frontend/dist/
dist/

# IDE / editor local state
.idea/
.vscode/
*.swp
*.swo

# Local Codex / temporary test files
.codex_tmp_test/
tmp/
*.tmp

# Runtime state generated by agent/server
agent_work/
server/data/
server/logs/
server/webui/
artifacts/

# Upload/object stores and generated archives
server/data/object_store/
server/data/tmp_uploads_v1/
server/data/guard_state/
server/data/assets/

# Databases and logs
*.db
*.sqlite
*.sqlite3
*.log

# Packaged binaries and generated executables
*.exe
*.dll
*.so
*.dylib
*.msi

# Large generated model/artifact bundles
server/artifacts/models/
server/artifacts/models.zip
server/artifacts/*.exe
server/artifacts/__pycache__/

# Keep source helpers in server/artifacts if needed
!server/artifacts/
!server/artifacts/*.py

# Build artifacts
build/
*.spec.bak

# Local secrets / environment files
.env
.env.*
!.env.example
deploy/server-production/.env

# Generated reports and user data
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.csv
*.png
*.jpg
*.jpeg
*.bmp

# Allow project documentation in markdown
!*.md
